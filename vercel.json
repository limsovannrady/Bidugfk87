{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm install && pnpm --filter @workspace/bot-dashboard run build",
  "outputDirectory": "artifacts/bot-dashboard/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "BASE_PATH": "/"
  }
}
